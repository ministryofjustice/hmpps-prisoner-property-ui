{% extends "../partials/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% set pageTitle = applicationName + " - Person property" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back to property list", href: backUrl }) }}
{% endblock %}

{% block content %}
  {% if successMessage %}
    {{ govukNotificationBanner({
      type: "success",
      text: successMessage,
      attributes: { "data-qa": "success-banner" }
    }) }}
  {% endif %}

  <h1 class="govuk-heading-xl govuk-!-margin-bottom-2" data-qa="prisoner-name">
    {{ (prisonerName | convertToTitleCase) or "Unknown" }}’s property
  </h1>
  <p class="govuk-body" data-qa="prisoner-establishment">
    Prison number: {{ prisonerNumber }}<br>
    Current establishment: {{ prisonerCurrentPrisonName or "Not known" }}
  </p>

  {% if canManage %}
    {{ govukButton({
      text: "Add property",
      href: "/prisoner/" + prisonerNumber + "/add-container",
      attributes: { "data-qa": "add-property" }
    }) }}
  {% endif %}

  {% if hasLeft %}
    {{ govukInsetText({
      attributes: { "data-qa": "left-establishment-warning" },
      html: "<strong>This person is no longer in this establishment.</strong><br>You should check if their property is still in storage at this establishment and update the details if necessary."
    }) }}
  {% endif %}

  {% if inEstablishment.length == 0 and dueToTransferIn.length == 0 %}
    <p class="govuk-body" data-qa="no-results">No property found for this person.</p>
  {% else %}
    <h2 class="govuk-heading-l govuk-!-margin-top-6">Property in this establishment</h2>
    {% if inEstablishment.length == 0 %}
      <p class="govuk-body" data-qa="no-in-establishment">No property is being held in this establishment for this person.</p>
    {% else %}
      {% set inEstablishmentHead = [{ text: "Seal number" }] %}
      {% if hasLeft %}
        {% set inEstablishmentHead = (inEstablishmentHead.push({ text: "Prisoner establishment" }), inEstablishmentHead) %}
      {% endif %}
      {% set inEstablishmentHead = (inEstablishmentHead.push(
        { text: "Property type" },
        { text: "Storage location" },
        { text: "Disposal date" },
        { text: "Last updated" },
        { text: "Property status" },
        { text: "Actions" }
      ), inEstablishmentHead) %}

      {% set inEstablishmentRows = [] %}
      {% for row in inEstablishment %}
        {% set cells = [{ text: row.container.currentSealNumber or "-" }] %}
        {% if hasLeft %}
          {% set cells = (cells.push({ text: prisonerCurrentPrisonName or "Not known" }), cells) %}
        {% endif %}
        {% set cells = (cells.push(
          { text: row.container.containerType | containerTypeLabel },
          { text: row.container | containerLocation },
          { text: (row.container.proposedDisposalDate | formatShortDate) or "No date set" },
          { text: row.container.createDateTime | formatShortDate },
          { html: govukTag({ text: row.status.text, classes: row.status.classes }) },
          { html: '<a class="govuk-link" href="/prisoner/' + prisonerNumber + '/container/' + row.container.id + '">View history</a>' }
        ), cells) %}
        {% set inEstablishmentRows = (inEstablishmentRows.push(cells), inEstablishmentRows) %}
      {% endfor %}

      {{ govukTable({
        attributes: { "data-qa": "in-establishment" },
        head: inEstablishmentHead,
        rows: inEstablishmentRows
      }) }}
    {% endif %}

    {% if dueToTransferIn.length %}
      <h2 class="govuk-heading-l govuk-!-margin-top-6">Property due to be transferred in</h2>
      {% set transferInRows = [] %}
      {% for row in dueToTransferIn %}
        {% set transferInRows = (transferInRows.push([
          { text: row.container.currentSealNumber or "-" },
          { text: row.container.containerType | containerTypeLabel },
          { text: row.container.prisonName or "-" },
          { text: (row.container.proposedDisposalDate | formatShortDate) or "No date set" },
          { text: row.container.createDateTime | formatShortDate },
          { html: govukTag({ text: row.status.text, classes: row.status.classes }) }
        ]), transferInRows) %}
      {% endfor %}

      {{ govukTable({
        attributes: { "data-qa": "due-transfer-in" },
        head: [
          { text: "Seal number" },
          { text: "Property type" },
          { text: "Establishment" },
          { text: "Disposal date" },
          { text: "Last updated" },
          { text: "Property status" }
        ],
        rows: transferInRows
      }) }}
    {% endif %}
  {% endif %}
{% endblock %}
