{% extends "../../partials/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% set pageTitle = applicationName + " - Change a property container" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}
{% endblock %}

{% block content %}
  {% if errorBanner %}
    {{ govukNotificationBanner({ titleText: "There is a problem", text: errorBanner, attributes: { "data-qa": "error-banner" } }) }}
  {% endif %}

  {% if errorList.length %}
    {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorList }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl" data-qa="change-container-heading">Change property container {{ container.currentSealNumber }}</h1>
    </div>
    <div class="govuk-grid-column-one-third govuk-!-text-align-right">
      {{ govukButton({ text: "Remove container", href: removeUrl, classes: "govuk-button--warning", attributes: { "data-qa": "remove-container-button" } }) }}
    </div>
  </div>

  {{ govukSummaryList({
    attributes: { "data-qa": "prisoner-summary" },
    rows: [
      { key: { text: "Name" }, value: { text: (prisonerName | convertToTitleCase) or "Unknown" } },
      { key: { text: "Prison number" }, value: { text: prisonerNumber } },
      { key: { text: "Prisoner establishment" }, value: { text: prisonerEstablishment or "Not known" } },
      { key: { text: "Property status" }, value: { html: govukTag({ text: status.text, classes: status.classes }) } }
    ]
  }) }}

  {% if disposal %}
    <div class="app-disposal-banner{{ ' app-disposal-banner--overdue' if disposal.overdue }}" data-qa="disposal-banner">
      {% if disposal.overdue %}
        <svg class="app-disposal-banner__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" aria-hidden="true" focusable="false">
          <path d="M15 2 L29 28 L1 28 Z" fill="#f47738"/>
          <rect x="13.5" y="11" width="3" height="8" fill="#ffffff"/>
          <rect x="13.5" y="21" width="3" height="3" fill="#ffffff"/>
        </svg>
        <div>
          <p class="app-disposal-banner__title">Disposal of the contents of this property container is overdue</p>
          <p class="app-disposal-banner__body">Check if the property container contents have been disposed and then <a class="govuk-link" href="{{ removeUrl }}">remove this container record</a></p>
        </div>
      {% else %}
        <svg class="app-disposal-banner__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" aria-hidden="true" focusable="false">
          <circle cx="15" cy="15" r="15" fill="#1d70b8"/>
          <rect x="13.5" y="13" width="3" height="9" fill="#ffffff"/>
          <rect x="13.5" y="8" width="3" height="3" fill="#ffffff"/>
        </svg>
        <div>
          <p class="app-disposal-banner__title">The contents of this property container is due for disposal on {{ disposal.date | formatDate }}</p>
          <p class="app-disposal-banner__body">When the property container contents have been disposed <a class="govuk-link" href="{{ removeUrl }}">remove this container record</a></p>
        </div>
      {% endif %}
    </div>
  {% endif %}

  <form method="post" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    {{ govukInput({
      label: { text: "Property container’s seal number", classes: "govuk-label--m" },
      hint: { text: "The seal number fitted to the container now." },
      id: "sealNumber",
      name: "sealNumber",
      value: data.sealNumber,
      classes: "govuk-input--width-20",
      errorMessage: { text: errors.sealNumber.text } if errors.sealNumber else undefined
    }) }}

    {{ govukRadios({
      idPrefix: "containerType",
      name: "containerType",
      fieldset: { legend: { text: "Type of property", classes: "govuk-fieldset__legend--m" } },
      items: containerTypes,
      errorMessage: { text: errors.containerType.text } if errors.containerType else undefined
    }) }}

    {{ govukDateInput({
      id: "disposalDate",
      namePrefix: "disposalDate",
      fieldset: { legend: { text: "Enter or select a date the property must be destroyed or disposed of (optional)", classes: "govuk-fieldset__legend--m" } },
      hint: { text: "For example, 17 1 2026." },
      errorMessage: { text: errors.disposalDate.text } if errors.disposalDate else undefined,
      items: [
        { name: "day", classes: "govuk-input--width-2", value: data.day },
        { name: "month", classes: "govuk-input--width-2", value: data.month },
        { name: "year", classes: "govuk-input--width-4", value: data.year }
      ]
    }) }}

    {% set locationItems = [] %}
    {% if hasCurrentLocation %}
      {% set locationItems = (locationItems.push({ value: "current", text: currentLocationName, checked: data.locationChoice != "new" }), locationItems) %}
    {% endif %}
    {% set locationItems = (locationItems.push({ value: "new", text: "a new storage location", checked: (data.locationChoice == "new") or (not hasCurrentLocation) }), locationItems) %}

    {{ govukRadios({
      idPrefix: "locationChoice",
      name: "locationChoice",
      fieldset: { legend: { text: "Storage location", classes: "govuk-fieldset__legend--m" } },
      items: locationItems
    }) }}

    {{ govukButton({ text: "Save and continue" }) }}
  </form>

  <p class="govuk-body"><a class="govuk-link" href="{{ backUrl }}" data-qa="cancel">Cancel</a></p>
{% endblock %}
