{% extends "../../partials/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% set pageTitle = applicationName + " - Remove property container" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}
{% endblock %}

{% block content %}
  {% if errorBanner %}
    {{ govukNotificationBanner({ titleText: "There is a problem", text: errorBanner, attributes: { "data-qa": "error-banner" } }) }}
  {% endif %}

  {% if errorList.length %}
    {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorList }) }}
  {% endif %}

  <h1 class="govuk-heading-xl" data-qa="remove-container-heading">
    Remove property container {{ container.currentSealNumber }}
  </h1>

  {{ govukSummaryList({
    attributes: { "data-qa": "prisoner-summary" },
    rows: [
      { key: { text: "Name" }, value: { text: (prisonerName | convertToTitleCase) or "Unknown" } },
      { key: { text: "Prison number" }, value: { text: prisonerNumber } },
      { key: { text: "Prisoner establishment" }, value: { text: prisonerEstablishment or "Not known" } }
    ]
  }) }}

  {{ govukSummaryList({
    attributes: { "data-qa": "container-summary" },
    rows: [
      { key: { text: "Seal number" }, value: { text: container.currentSealNumber or "-" } },
      { key: { text: "Property type" }, value: { text: container.containerType | containerTypeLabel } },
      { key: { text: "Storage location" }, value: { text: container | containerLocation } },
      { key: { text: "Disposal date" }, value: { text: (container.proposedDisposalDate | formatDate) if container.proposedDisposalDate else "No date set" } },
      { key: { text: "Property status" }, value: { html: govukTag({ text: status.text, classes: status.classes }) } }
    ]
  }) }}

  <form method="post" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    {{ govukRadios({
      idPrefix: "outcome",
      name: "outcome",
      fieldset: { legend: { text: "Why are you removing this property container record?", classes: "govuk-fieldset__legend--m" } },
      items: reasons,
      errorMessage: { text: errorList[0].text } if errorList.length else undefined
    }) }}

    {{ govukButton({ text: "Remove container", attributes: { "data-qa": "remove-container" } }) }}
  </form>

  <p class="govuk-body"><a class="govuk-link" href="{{ backUrl }}" data-qa="cancel">Cancel</a></p>
{% endblock %}
