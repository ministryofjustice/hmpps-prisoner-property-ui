{% extends "../../partials/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% set pageTitle = applicationName + " - Combine containers" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}
{% endblock %}

{% block content %}
  {% if errorBanner %}
    {{ govukNotificationBanner({ titleText: "There is a problem", text: errorBanner, attributes: { "data-qa": "error-banner" } }) }}
  {% endif %}

  {% if errorList.length %}
    {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorList }) }}
  {% endif %}

  <h1 class="govuk-heading-xl" data-qa="combine-heading">Combine containers</h1>

  {{ govukSummaryList({
    attributes: { "data-qa": "prisoner-summary" },
    rows: [
      { key: { text: "Name" }, value: { text: (prisonerName | convertToTitleCase) or "Unknown" } },
      { key: { text: "Prison number" }, value: { text: prisonerNumber } },
      { key: { text: "Prisoner establishment" }, value: { text: establishmentName or "Not known" } }
    ]
  }) }}

  <h2 class="govuk-heading-m govuk-!-margin-top-6">Property containers to combine</h2>

  {% set sourceRows = [] %}
  {% for row in sources %}
    {% set sourceRows = (sourceRows.push([
      { text: row.container.currentSealNumber or "-" },
      { text: row.container.containerType | containerTypeLabel },
      { text: (row.container.proposedDisposalDate | formatShortDate) or "No date set" },
      { html: govukTag({ text: row.status.text, classes: row.status.classes }) }
    ]), sourceRows) %}
  {% endfor %}

  {{ govukTable({
    attributes: { "data-qa": "sources" },
    head: [
      { text: "Seal number" },
      { text: "Property type" },
      { text: "Disposal date" },
      { text: "Property status" }
    ],
    rows: sourceRows
  }) }}

  <h2 class="govuk-heading-m govuk-!-margin-top-6">New combined container</h2>

  <form method="post" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    {{ govukInput({
      label: { text: "Enter the property container’s current seal number", classes: "govuk-label--m" },
      hint: { text: "The seal number fitted to the container now." },
      id: "sealNumber",
      name: "sealNumber",
      value: data.sealNumber,
      classes: "govuk-input--width-20",
      errorMessage: { text: errors.sealNumber.text } if errors.sealNumber else undefined
    }) }}

    {{ govukRadios({
      idPrefix: "containerType",
      name: "containerType",
      fieldset: { legend: { text: "What is the type of property?", classes: "govuk-fieldset__legend--m" } },
      items: containerTypes,
      errorMessage: { text: errors.containerType.text } if errors.containerType else undefined
    }) }}

    {{ govukDateInput({
      id: "disposalDate",
      namePrefix: "disposalDate",
      fieldset: { legend: { text: "Enter or select a date the property must be destroyed or disposed of (optional)", classes: "govuk-fieldset__legend--m" } },
      hint: { text: "For example, 17 1 2026." },
      errorMessage: { text: errors.disposalDate.text } if errors.disposalDate else undefined,
      items: [
        { name: "day", classes: "govuk-input--width-2", value: data.day },
        { name: "month", classes: "govuk-input--width-2", value: data.month },
        { name: "year", classes: "govuk-input--width-4", value: data.year }
      ]
    }) }}

    {{ govukButton({ text: "Save and continue" }) }}
  </form>

  <p class="govuk-body"><a class="govuk-link" href="{{ backUrl }}" data-qa="cancel">Cancel</a></p>
{% endblock %}
