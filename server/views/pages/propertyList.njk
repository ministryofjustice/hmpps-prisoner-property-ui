{% extends "../partials/layout.njk" %}

{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "moj/components/pagination/macro.njk" import mojPagination %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% set pageTitle = applicationName + " - Property" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}
  {{ govukBreadcrumbs({ items: [
    { text: "Digital Prison Services", href: dpsUrl },
    { text: "Prisoner property" }
  ] }) }}
{% endblock %}

{% block content %}
  {% if successMessage %}
    {{ govukNotificationBanner({
      type: "success",
      text: successMessage,
      attributes: { "data-qa": "success-banner" }
    }) }}
  {% endif %}

  <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">
    Prisoner property{% if establishmentName %} <span class="govuk-!-font-weight-regular">— {{ establishmentName }}</span>{% endif %}
  </h1>

  {% if canManage %}
    {{ govukButton({
      text: "Add a property container",
      href: "#",
      attributes: { "data-qa": "add-container" }
    }) }}
  {% endif %}

  {% if summary %}
    {% set tiles = [
      { text: "Available storage locations on-site", value: summary.availableStorageLocations, qa: "summary-available-locations" },
      { text: "Property containers stored on-site", value: summary.storedOnSite, qa: "summary-stored" },
      { text: "Property containers due to transfer out", value: summary.dueToTransferOut, qa: "summary-transfer-out" },
      { text: "Property containers due to be returned", value: summary.dueToBeReturned, qa: "summary-returned" },
      { text: "Property containers due to be disposed", value: summary.dueToBeDisposed, qa: "summary-disposed" }
    ] %}
    <div class="property-summary" data-qa="property-summary">
      {% for tile in tiles %}
        <div class="property-summary__card">
          <p class="property-summary__caption">{{ tile.text }}</p>
          <p class="property-summary__value" data-qa="{{ tile.qa }}">{{ tile.value }}</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <div class="app-search-panel">
    <form method="get" action="/" novalidate data-qa="property-search">
      <h2 class="govuk-heading-m">Search for property</h2>
      <p class="govuk-hint">You can search by prison number, seal number or storage location number</p>

      <div class="app-search-panel__row">
        {{ govukInput({
          label: { text: "Search for property", classes: "govuk-visually-hidden" },
          id: "q",
          name: "q",
          value: search,
          classes: "govuk-input--width-20",
          formGroup: { classes: "app-search-panel__input" }
        }) }}
        {{ govukButton({ text: "Search", classes: "app-search-panel__button" }) }}
        <a class="govuk-link app-search-panel__clear" href="/">Clear search</a>
      </div>

      <details class="govuk-details app-search-panel__filters" data-qa="filters">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">Filters</span>
        </summary>
        <div class="govuk-details__text">
          {{ govukCheckboxes({
            idPrefix: "containerType",
            name: "containerType",
            classes: "govuk-checkboxes--small app-checkboxes--inline",
            fieldset: { legend: { text: "By property type", classes: "govuk-fieldset__legend--s" } },
            items: containerTypeItems
          }) }}

          {{ govukCheckboxes({
            idPrefix: "status",
            name: "status",
            classes: "govuk-checkboxes--small app-checkboxes--inline",
            fieldset: { legend: { text: "By property status", classes: "govuk-fieldset__legend--s" } },
            items: statusItems
          }) }}

          {{ govukCheckboxes({
            idPrefix: "personLocation",
            name: "personLocation",
            classes: "govuk-checkboxes--small app-checkboxes--inline",
            fieldset: { legend: { text: "By person location", classes: "govuk-fieldset__legend--s" } },
            items: [
              { value: "IN_ESTABLISHMENT", text: "Property for people in this establishment", disabled: true },
              { value: "LEFT_ESTABLISHMENT", text: "Property for people no longer in this establishment", disabled: true }
            ]
          }) }}

          {{ govukCheckboxes({
            idPrefix: "includeRemoved",
            name: "includeRemoved",
            classes: "govuk-checkboxes--small",
            fieldset: { legend: { text: "By property returned or disposed", classes: "govuk-fieldset__legend--s" } },
            items: [
              { value: "true", text: "Show property that has been returned or disposed of", checked: includeRemoved }
            ]
          }) }}

          {{ govukButton({ text: "Apply filters" }) }}
          <a class="govuk-link govuk-!-margin-left-2" href="/">Clear filters</a>
        </div>
      </details>
    </form>
  </div>

  {% if groups.length == 0 %}
    <p class="govuk-body" data-qa="no-results">No property containers found.</p>
  {% else %}
    {% set tableHead = [
      { text: "Name" },
      { text: "Prisoner establishment" },
      { text: "Seal number" },
      { text: "Property type" },
      { text: "Storage location" },
      { text: "Last updated" },
      { text: "Property status" }
    ] %}
    {% if canManage %}
      {% set tableHead = (tableHead.push({ text: "Actions" }), tableHead) %}
    {% endif %}

    {% set rows = [] %}
    {% for group in groups %}
      {% for container in group.containers %}
        {% set statusData = container.currentStatus | statusTag %}
        {% set cells = [] %}
        {% if loop.first %}
          {% set nameHtml %}
            <a class="govuk-link" href="/prisoner/{{ group.prisonerNumber }}">{{ (group.prisonerName | convertToTitleCase) or "Unknown" }}</a>
            <div class="govuk-!-font-weight-regular">{{ group.prisonerNumber }}</div>
          {% endset %}
          {% set cells = (cells.push(
            { html: nameHtml, rowspan: group.containers.length, attributes: { "data-qa": "prisoner-heading" } },
            { text: group | establishmentLabel, rowspan: group.containers.length, attributes: { "data-qa": "prisoner-establishment" } }
          ), cells) %}
        {% endif %}
        {% set cells = (cells.push(
          { text: container.currentSealNumber or "-" },
          { text: container.containerType | containerTypeLabel },
          { text: container | containerLocation },
          { text: container.createDateTime | formatShortDate },
          { html: govukTag({ text: statusData.text, classes: statusData.classes }) }
        ), cells) %}
        {% if canManage %}
          {% set actionsHtml %}<a class="govuk-link" href="/prisoner/{{ group.prisonerNumber }}/change-container/{{ container.id }}?from=list" data-qa="change-link">Change<span class="govuk-visually-hidden"> {{ container.currentSealNumber }}</span></a> | <a class="govuk-link" href="/prisoner/{{ group.prisonerNumber }}/remove-container/{{ container.id }}?from=list" data-qa="remove-link">Remove<span class="govuk-visually-hidden"> {{ container.currentSealNumber }}</span></a>{% endset %}
          {% set cells = (cells.push({ html: actionsHtml }), cells) %}
        {% endif %}
        {% set rows = (rows.push(cells), rows) %}
      {% endfor %}
    {% endfor %}

    {{ mojPagination(pagination) }}

    {{ govukTable({
      classes: "govuk-!-font-size-16",
      attributes: { "data-qa": "property-list" },
      head: tableHead,
      rows: rows
    }) }}

    {{ mojPagination(pagination) }}
  {% endif %}
{% endblock %}
