{% extends "../../partials/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set pageTitle = applicationName + " - Add a property container" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}
{% endblock %}

{% block content %}
  {% if errorBanner %}
    {{ govukNotificationBanner({ titleText: "There is a problem", text: errorBanner, attributes: { "data-qa": "error-banner" } }) }}
  {% endif %}

  {% if errorList.length %}
    {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorList }) }}
  {% endif %}

  <h1 class="govuk-heading-xl" data-qa="add-container-heading">Add a property container</h1>

  {{ govukSummaryList({
    attributes: { "data-qa": "prisoner-summary" },
    rows: [
      { key: { text: "Name" }, value: { text: (prisonerName | convertToTitleCase) or "Unknown" } },
      { key: { text: "Prison number" }, value: { text: prisonerNumber } },
      { key: { text: "Prisoner establishment" }, value: { text: establishmentName or "Not known" } }
    ]
  }) }}

  <form method="post" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    {% for container in containers %}
      {% set i = loop.index0 %}
      {% set prefix = "containers[" + i + "]" %}
      {% set idPrefix = "containers-" + i %}

      {% if i > 0 %}
        <h2 class="govuk-heading-m govuk-!-margin-top-6" data-qa="another-heading">Add another property container</h2>
      {% endif %}

      {{ govukInput({
        label: { text: "Enter the property container’s current seal number", classes: "govuk-label--m" },
        hint: { text: "The seal number fitted to the container now." },
        id: idPrefix + "-sealNumber",
        name: prefix + "[sealNumber]",
        value: container.sealNumber,
        classes: "govuk-input--width-20",
        errorMessage: { text: fieldErrors[idPrefix + "-sealNumber"] } if fieldErrors[idPrefix + "-sealNumber"] else undefined
      }) }}

      {{ govukInput({
        label: { text: "Previous or different seal number (optional)", classes: "govuk-label--m" },
        hint: { text: "Leave this blank if the container is new, or if you do not know another seal number." },
        id: idPrefix + "-previousSealNumber",
        name: prefix + "[previousSealNumber]",
        value: container.previousSealNumber,
        classes: "govuk-input--width-20"
      }) }}

      {{ govukDetails({
        summaryText: "Why do we ask for this",
        text: "Recording a previous seal number lets us link a container to its record at another establishment, so property can be tracked when a person transfers."
      }) }}

      {% set typeItems = [] %}
      {% for type in containerTypes %}
        {% set typeItems = (typeItems.push({ value: type.value, text: type.text, checked: type.value == container.containerType }), typeItems) %}
      {% endfor %}
      {{ govukRadios({
        idPrefix: idPrefix + "-containerType",
        name: prefix + "[containerType]",
        fieldset: { legend: { text: "What is the type of property?", classes: "govuk-fieldset__legend--m" } },
        items: typeItems,
        errorMessage: { text: fieldErrors[idPrefix + "-containerType"] } if fieldErrors[idPrefix + "-containerType"] else undefined
      }) }}

      {{ govukDateInput({
        id: idPrefix + "-disposalDate",
        fieldset: { legend: { text: "Enter or select a date the property must be destroyed or disposed of (optional)", classes: "govuk-fieldset__legend--m" } },
        hint: { text: "For example, 17 1 2026." },
        errorMessage: { text: fieldErrors[idPrefix + "-disposalDate"] } if fieldErrors[idPrefix + "-disposalDate"] else undefined,
        items: [
          { id: idPrefix + "-disposalDate-day", name: prefix + "[disposalDate][day]", label: "Day", classes: "govuk-input--width-2", value: container.disposalDate.day },
          { id: idPrefix + "-disposalDate-month", name: prefix + "[disposalDate][month]", label: "Month", classes: "govuk-input--width-2", value: container.disposalDate.month },
          { id: idPrefix + "-disposalDate-year", name: prefix + "[disposalDate][year]", label: "Year", classes: "govuk-input--width-4", value: container.disposalDate.year }
        ]
      }) }}

      {% if not loop.last %}<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">{% endif %}
    {% endfor %}

    {{ govukButton({
      text: "Add another property container for this person",
      classes: "govuk-button--secondary",
      name: "action",
      value: "addAnother",
      attributes: { "data-qa": "add-another" }
    }) }}

    <div class="govuk-button-group govuk-!-margin-top-4">
      {{ govukButton({ text: "Save and continue", attributes: { "data-qa": "save-and-continue" } }) }}
    </div>
  </form>

  <p class="govuk-body"><a class="govuk-link" href="{{ backUrl }}" data-qa="cancel">Cancel</a></p>
{% endblock %}
