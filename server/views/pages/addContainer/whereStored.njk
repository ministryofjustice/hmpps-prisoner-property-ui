{% extends "../../partials/layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% set pageTitle = applicationName + " - Where is this excess property stored?" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back", href: backUrl }) }}
{% endblock %}

{% block content %}
  {% if errorBanner %}
    {{ govukNotificationBanner({ titleText: "There is a problem", text: errorBanner, attributes: { "data-qa": "error-banner" } }) }}
  {% endif %}

  <form method="post" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    {{ govukRadios({
      idPrefix: "storageChoice",
      name: "storageChoice",
      fieldset: {
        legend: {
          text: "Where is excess property container " + sealNumber + " stored?",
          isPageHeading: true,
          classes: "govuk-fieldset__legend--xl"
        }
      },
      items: [
        { value: "branston", text: "Off-site at Branston", checked: storageChoice == "branston" },
        { value: "internal", text: "A location in this prison", checked: storageChoice == "internal" }
      ]
    }) }}

    {{ govukButton({ text: "Continue", attributes: { "data-qa": "submit" } }) }}
  </form>
{% endblock %}
