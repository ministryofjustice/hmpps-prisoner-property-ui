{% extends "../partials/layout.njk" %}

{% set pageTitle = applicationName + " - No caseload" %}
{% set mainClasses = "govuk-body" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">You do not have an active caseload</h1>
      <p class="govuk-body">
        You need an active caseload for an establishment to view its prisoner property. Set an active
        caseload in DPS, or contact your Local System Administrator if you think this is wrong.
      </p>
    </div>
  </div>
{% endblock %}
